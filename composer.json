{
  "name": "marnap889/medical-appointment-api",
  "description": "AI-first medical appointment API built with Symfony 7.4 and PHP 8.5",
  "type": "project",
  "license": "proprietary",
  "require": {
    "php": "^8.5",
    "ext-ctype": "*",
    "ext-iconv": "*",
    "symfony/console": "^7.4",
    "symfony/dotenv": "^7.4",
    "symfony/flex": "^2.8",
    "symfony/framework-bundle": "^7.4",
    "symfony/http-foundation": "^7.4",
    "symfony/http-kernel": "^7.4",
    "symfony/routing": "^7.4",
    "symfony/serializer": "^7.4",
    "symfony/validator": "^7.4",
    "symfony/security-csrf": "^7.4",
    "symfony/dependency-injection": "^7.4",
    "symfony/yaml": "^7.4",
    "doctrine/dbal": "^4.3",
    "doctrine/orm": "^3.4",
    "doctrine/doctrine-bundle": "^3.0",
    "doctrine/doctrine-migrations-bundle": "^4.0",
    "nelmio/cors-bundle": "^2.6",
    "nelmio/api-doc-bundle": "^5.8",
    "symfony/uid": "^7.4",
    "symfony/twig-bundle": "^7.4",
    "symfony/asset": "^7.4"
  },
  "require-dev": {
    "phpunit/phpunit": "^12.0",
    "phpstan/phpstan": "^2.1",
    "phpstan/phpstan-symfony": "^2.0",
    "friendsofphp/php-cs-fixer": "^3.80",
    "behat/behat": "3.29.0",
    "friends-of-behat/symfony-extension": "2.6.2",
    "symfony/browser-kit": "^7.4",
    "symfony/css-selector": "^7.4",
    "symfony/maker-bundle": "^1.65"
  },
  "autoload": {
    "psr-4": {
      "App\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "App\\Tests\\": "tests/"
    }
  },
  "scripts": {
    "post-install-cmd": [
      "@php bin/console cache:clear"
    ],
    "post-update-cmd": [
      "@php bin/console cache:clear"
    ],
    "test": "vendor/bin/phpunit",
    "test:unit": "vendor/bin/phpunit --testsuite Unit",
    "test:behat": "vendor/bin/behat -c behat.yml.dist",
    "phpstan": "vendor/bin/phpstan analyse",
    "cs": "vendor/bin/php-cs-fixer fix --dry-run --diff",
    "cs:fix": "vendor/bin/php-cs-fixer fix"
  },
  "extra": {
    "symfony": {
      "allow-contrib": false,
      "require": "^7.4"
    }
  },
  "minimum-stability": "stable",
  "prefer-stable": true,
  "config": {
    "allow-plugins": {
      "symfony/flex": true
    }
  }
}
